# Database - PostgreSQL
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/implant_service?schema=public"

# NextAuth - Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="https://isc.ikalab.vn"

# MinIO S3-compatible storage
MINIO_ENDPOINT="your-minio-host"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="implant-service"
MINIO_USE_SSL="true"

# App
NEXT_PUBLIC_APP_NAME="Implant Service Center"
NEXT_PUBLIC_APP_URL="https://isc.ikalab.vn"
